{
  "name": "meuplayer",
  "version": "1.1.0",
  "description": "MeuPlayer Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "python scripts/generate-icons.py",
    "build:server": "powershell -ExecutionPolicy Bypass -File scripts/build-server.ps1",
    "build:win": "npm run icons && npm run build:server && electron-builder --win",
    "build:linux": "npm run icons && npm run build:server && electron-builder --linux",
    "build:mac": "npm run icons && npm run build:server && electron-builder --mac"
  },
  "build": {
    "appId": "com.meuplayer.app",
    "productName": "MeuPlayer",
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "public/**/*",
      "!public/cache/**"
    ],
    "extraResources": [
      {
        "from": "dist-server/meuplayer-server.exe",
        "to": "."
      },
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*", "!cache/**"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
