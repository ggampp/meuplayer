# Copie para .env e ajuste (não commite o .env)

TMDB_API_KEY=sua_chave_tmdb

# Cache de API / metadados TMDB
# Vazio ou omitido = SQLite em %APPDATA%/meuplayer/cache.sqlite3 (ou pasta do projeto)
# CACHE_DATABASE_URL=sqlite

# PostgreSQL — local ou VPS
# CACHE_DATABASE_URL=postgresql://meuplayer:senha@localhost:5432/meuplayer
